APP_NAME=China Web API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
# Default local setup uses SQLite and the file `backend/china_web.db`.
DATABASE_URL=sqlite:///./china_web.db
# Optional PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:<REAL_POSTGRES_PASSWORD>@127.0.0.1:5432/china_web_db
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
TRUSTED_HOSTS=["localhost","127.0.0.1"]
DOCS_ENABLED=true
UPLOAD_DIR=uploads
UPLOAD_URL_PREFIX=/uploads
MAX_UPLOAD_SIZE_MB=20
MEDIA_STORAGE=local
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=china-web
AUTH_SECRET_KEY=change-this-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-this-admin-password
LOG_LEVEL=INFO
