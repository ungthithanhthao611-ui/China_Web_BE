APP_NAME=China Web API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
# Default local setup uses SQLite and the file `backend/china_web.db`.
DATABASE_URL=sqlite:///./china_web.db
# Optional PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:<REAL_POSTGRES_PASSWORD>@127.0.0.1:5432/china_web_db
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
TRUSTED_HOSTS=["localhost","127.0.0.1"]
DOCS_ENABLED=true
UPLOAD_DIR=uploads
UPLOAD_URL_PREFIX=/uploads
MAX_UPLOAD_SIZE_MB=50
MEDIA_STORAGE=local
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=china-web
WP_BASE_URL=
WP_USERNAME=
WP_APP_PASSWORD=
WP_AUTO_SYNC_ENABLED=false
WP_AUTO_SYNC_INTERVAL_SECONDS=300
WP_AUTO_SYNC_LANGUAGE_CODE=en
WP_AUTO_SYNC_STATUS=publish
WP_AUTO_SYNC_PER_PAGE=50
WP_AUTO_SYNC_MAX_PAGES=10
WP_BIDIRECTIONAL_DELETE_ENABLED=false
ONLYOFFICE_DOCUMENT_SERVER_URL=http://127.0.0.1:8082
ONLYOFFICE_CALLBACK_BASE_URL=http://127.0.0.1:8000
ONLYOFFICE_JWT_SECRET=change-this-onlyoffice-secret
ONLYOFFICE_STORAGE_DIR=uploads/post-documents
ONLYOFFICE_DOCX_PUBLIC_BASE_URL=http://127.0.0.1:8000/uploads/post-documents
ONLYOFFICE_AUTO_CONVERT_ON_CALLBACK=true
AUTH_SECRET_KEY=change-this-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-this-admin-password
LOG_LEVEL=INFO
